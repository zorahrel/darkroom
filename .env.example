# Darkroom configuration — copy to .env and adjust. All values are optional;
# the defaults shown make Darkroom store everything under ~/Darkroom.

# --- Storage --------------------------------------------------------------
# Root folder for gallery data + the SQLite DB.
# GALLERY_ROOT=~/Darkroom
# Override individual locations if you want (default: <root>/data/<name>):
# GALLERY_DATA_DIR=
# GALLERY_RAW_DIR=          # originals to import (immutable)
# GALLERY_IMPORT_DIR=       # pre-existing renders to reconcile as "orphans"
# GALLERY_GEN_DIR=          # worker outputs
# GALLERY_FINAL_DIR=        # exported favorites
# DARKROOM_DB=              # explicit path to photos.db

# --- Server ---------------------------------------------------------------
# PORT=3535                 # backend (frontend dev server defaults to 5173)

# --- Backend selection ----------------------------------------------------
# WORKER_BACKEND=cdp        # "cdp" = ChatGPT web over CDP (default, free)
#                           # "codex" = Codex CLI (OAuth, no Chrome)

# --- ChatGPT-web (CDP) backend -------------------------------------------
# CHATGPT_CDP_PORT=19223
# CHATGPT_CDP_URL=http://127.0.0.1:19223
# CHROME_BIN=               # path to Chrome/Chromium if auto-detect fails
# DARKROOM_CHROME_PROFILE=  # persistent Chrome profile (holds the ChatGPT login)
# GEN_TIMEOUT_S=540         # max seconds to wait for one generation

# --- Codex backend (optional) --------------------------------------------
# CODEX_BIN=/Applications/Codex.app/Contents/Resources/codex

# --- Higgsfield backend (optional, paid) ---------------------------------
# Enable by completing the OAuth flow (writes data/higgsfield.json) or:
# HIGGSFIELD_ENABLED=1
